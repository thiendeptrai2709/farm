    m_Metadata:
      m_Items: []
  - m_Id: 8365340518965248
    m_Localized: "B\u01A1"
    m_Metadata:
      m_Items: []
  - m_Id: 8365342834221056
    m_Localized: "C\xE0 r\u1ED1t"
    m_Metadata:
      m_Items: []
  - m_Id: 8365350782427136
    m_Localized: "L\xEA"
    m_Metadata:
      m_Items: []
  - m_Id: 8365351524818944
    m_Localized: "D\u1EE9a"
    m_Metadata:
      m_Items: []
  - m_Id: 8365352330125312
    m_Localized: "Khoai t\xE2y"
    m_Metadata:
      m_Items: []
  - m_Id: 8365353064128512
    m_Localized: "B\xED \u0111\u1ECF"
    m_Metadata:
      m_Items: []
  - m_Id: 8365353772965888
    m_Localized: "C\u1EE7 c\u1EA3i"
    m_Metadata:
      m_Items: []
  - m_Id: 8365356121776128
    m_Localized: "C\xE0 chua"
    m_Metadata:
      m_Items: []
  - m_Id: 8365357531062272
    m_Localized: "D\u01B0a h\u1EA5u"
    m_Metadata:
      m_Items: []
  - m_Id: 8366121934577664
    m_Localized: "H\u1EA1t gi\u1ED1ng t\xE1o"
    m_Metadata:
      m_Items: []
  - m_Id: 8366122601472000
    m_Localized: "H\u1EA1t gi\u1ED1ng b\u01A1"
    m_Metadata:
      m_Items: []
  - m_Id: 8366295843004416
    m_Localized: "H\u1EA1t gi\u1ED1ng c\xE0 r\u1ED1t"
    m_Metadata:
      m_Items: []
  - m_Id: 8366298934206464
    m_Localized: "H\u1EA1t gi\u1ED1ng l\xFAa m\xEC "
    m_Metadata:
      m_Items: []
  - m_Id: 8366301081690112
    m_Localized: "H\u1EA1t gi\u1ED1ng t\u1ECFi"
    m_Metadata:
      m_Items: []
  - m_Id: 8366123377418240
    m_Localized: "H\u1EA1t gi\u1ED1ng chanh"
    m_Metadata:
      m_Items: []
  - m_Id: 8366124082061312
    m_Localized: "H\u1EA1t gi\u1ED1ng xo\xE0i"
    m_Metadata:
      m_Items: []
  - m_Id: 8366131799580672
    m_Localized: "H\u1EA1t gi\u1ED1ng h\xE0nh t\xE2y"
    m_Metadata:
      m_Items: []
  - m_Id: 8366139416436736
    m_Localized: "H\u1EA1t gi\u1ED1ng cam"
    m_Metadata:
      m_Items: []
  - m_Id: 8366142167900160
